{
  "name": "leidong-sanqian-vscode-tools",
  "displayName": "雷动三千vscode工具集",
  "description": "内部使用",
  "version": "3.0.1",
  "publisher": "KuCai",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lsrweb/leidong-tools.git"
  },
  "bugs": {
    "url": "https://github.com/lsrweb/leidong-tools/issues"
  },
  "homepage": "https://github.com/lsrweb/leidong-tools#readme",
  "keywords": [
    "雷动三千",
    "vue",
    "vue2",
    "cdn",
    "javascript",
    "html",
    "compression",
    "completion",
    "productivity",
    "tools",
    "definition",
    "jump",
    "中文",
    "开发工具",
    "效率工具"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Snippets",
    "Linters",
    "Data Science",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onView:leidong-tools.sftpView",
    "onTerminalProfile:leidong-tools.remoteTerminal",
    "onCommand:leidong-tools.remoteTerminal.open",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "leidong-tools",
        "displayName": "雷动自定义端点（DeepSeek / MiMo）"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          ".vscode/sftp.json",
          "**/.vscode/sftp.json"
        ],
        "url": "./schemas/sftp.schema.json"
      }
    ],
    "chatParticipants": [
      {
        "id": "leidong-tools.analyzer",
        "fullName": "雷动三千 Vue 分析",
        "name": "leidong-tools",
        "description": "分析 Vue 变量/方法的引用关系和逻辑依赖",
        "isSticky": false,
        "commands": [
          {
            "name": "analyze",
            "description": "分析变量或方法的所有引用和逻辑关系"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "leidong-tools.copilot.setDeepSeekApiKey",
        "title": "设置 DeepSeek API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.setMiMoApiKey",
        "title": "设置 MiMo 当前模式 API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.setMiMoTokenPlanApiKey",
        "title": "设置 MiMo TokenPlan API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.setMiMoPayAsYouGoApiKey",
        "title": "设置 MiMo 按量计费 API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.clearDeepSeekApiKey",
        "title": "清除 DeepSeek API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.clearMiMoApiKey",
        "title": "清除 MiMo API Key",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.copilot.showLogs",
        "title": "显示自定义端点日志",
        "category": "雷动三千工具集：自定义端点"
      },
      {
        "command": "leidong-tools.goToDefinitionInNewTab",
        "title": "HTML Vue: Go To Definition in New Tab",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.logVariable",
        "title": "Log Variable (console.log)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.errorVariable",
        "title": "Log Variable (console.error)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.infoVariable",
        "title": "Log Variable (console.info)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.debugVariable",
        "title": "Log Variable (console.debug)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.compressLines",
        "title": "Compress Multiple Lines",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.formatXTemplateSelection",
        "title": "格式化 text/x-template 选定内容",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.quickConsoleLog",
        "title": "Quick Console Log (Ctrl+L)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.quickConsoleError",
        "title": "Quick Console Error (Ctrl+E)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.logSelectedVariable",
        "title": "Log Selected Variable in Next Line (Ctrl+Shift+L)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.addVariableComment",
        "title": "Add Variable Comment",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.showPerformanceReport",
        "title": "Show Performance Report",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.clearIndexCache",
        "title": "Clear Vue Index Cache",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.buildCurrentVueIndex",
        "title": "构建索引",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.showIndexSummary",
        "title": "Show Index Summary (Template + Vue)",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.toggleIndexLogging",
        "title": "Toggle Index Logging",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.toggleDefinitionJump",
        "title": "Toggle Definition Jump Feature",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.startWatch",
        "title": "启动 HTML→JS 文件监听",
        "category": "雷动三千工具集",
        "icon": "$(eye)"
      },
      {
        "command": "leidong-tools.startWatchManual",
        "title": "启动 HTML→JS 文件监听（手动选择）",
        "category": "雷动三千工具集",
        "icon": "$(folder-open)"
      },
      {
        "command": "leidong-tools.showWatchList",
        "title": "查看/管理文件监听列表",
        "category": "雷动三千工具集",
        "icon": "$(list-unordered)"
      },
      {
        "command": "leidong-tools.pauseWatch",
        "title": "暂停监听",
        "category": "雷动三千工具集",
        "icon": "$(pause)"
      },
      {
        "command": "leidong-tools.resumeWatch",
        "title": "恢复监听",
        "category": "雷动三千工具集",
        "icon": "$(play)"
      },
      {
        "command": "leidong-tools.pauseAllWatches",
        "title": "暂停全部监听",
        "category": "雷动三千工具集",
        "icon": "$(debug-pause)"
      },
      {
        "command": "leidong-tools.resumeAllWatches",
        "title": "恢复全部监听",
        "category": "雷动三千工具集",
        "icon": "$(debug-continue)"
      },
      {
        "command": "leidong-tools.openGameLobby",
        "title": "打开小游戏大厅",
        "category": "雷动三千工具集",
        "icon": "$(game)"
      },
      {
        "command": "leidong-tools.setGameServerUrl",
        "title": "设置游戏服务器地址",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.changeGameNickname",
        "title": "修改游戏昵称",
        "category": "雷动三千工具集"
      },
      {
        "command": "leidong-tools.analyzeWithCopilot",
        "title": "AI 分析变量/方法引用关系",
        "category": "雷动三千工具集",
        "icon": "$(sparkle)"
      },
      {
        "command": "leidong-tools.switchAIModel",
        "title": "切换 AI 分析模型",
        "category": "雷动三千工具集",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "leidong-tools.sftp.refresh",
        "title": "刷新远程资源",
        "category": "雷动三千工具集",
        "icon": "$(refresh)"
      },
      {
        "command": "leidong-tools.sftp.openConfig",
        "title": "打开远程连接配置",
        "category": "雷动三千工具集",
        "icon": "$(gear)"
      },
      {
        "command": "leidong-tools.sftp.preview",
        "title": "预览远程文件",
        "category": "雷动三千工具集",
        "icon": "$(open-preview)"
      },
      {
        "command": "leidong-tools.sftp.download",
        "title": "下载远程资源",
        "category": "雷动三千工具集",
        "icon": "$(cloud-download)"
      },
      {
        "command": "leidong-tools.sftp.upload",
        "title": "上传到远程目录",
        "category": "雷动三千工具集",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "leidong-tools.sftp.uploadFile",
        "title": "上传文件",
        "category": "雷动三千工具集",
        "icon": "$(file)"
      },
      {
        "command": "leidong-tools.sftp.uploadFolder",
        "title": "上传文件夹到远程",
        "category": "雷动三千工具集",
        "icon": "$(folder)"
      },
      {
        "command": "leidong-tools.sftp.uploadCurrentFile",
        "title": "上传文件",
        "category": "雷动三千工具集",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "leidong-tools.sftp.backupUpload",
        "title": "备份并上传文件",
        "category": "雷动三千工具集",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "leidong-tools.sftp.downloadCurrentFile",
        "title": "下载文件",
        "category": "雷动三千工具集",
        "icon": "$(cloud-download)"
      },
      {
        "command": "leidong-tools.sftp.selectAutoUploadProfile",
        "title": "选择保存自动上传目标",
        "category": "雷动三千工具集",
        "icon": "$(target)"
      },
      {
        "command": "leidong-tools.sftp.toggleProfileAutoUpload",
        "title": "切换此连接自动上传",
        "category": "雷动三千工具集",
        "icon": "$(sync)"
      },
      {
        "command": "leidong-tools.sftp.showLogs",
        "title": "显示远程资源日志",
        "category": "雷动三千工具集",
        "icon": "$(output)"
      },
      {
        "command": "leidong-tools.sftp.toggleUploadOnSave",
        "title": "切换保存自动上传",
        "category": "雷动三千工具集",
        "icon": "$(sync)"
      },
      {
        "command": "leidong-tools.sftp.testConnection",
        "title": "测试远程连接",
        "category": "雷动三千工具集",
        "icon": "$(debug-start)"
      },
      {
        "command": "leidong-tools.sftp.disconnect",
        "title": "断开远程连接",
        "category": "雷动三千工具集",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "leidong-tools.sftp.createDirectory",
        "title": "新建远程目录",
        "category": "雷动三千工具集",
        "icon": "$(new-folder)"
      },
      {
        "command": "leidong-tools.sftp.rename",
        "title": "重命名远程资源",
        "category": "雷动三千工具集",
        "icon": "$(edit)"
      },
      {
        "command": "leidong-tools.sftp.delete",
        "title": "删除远程资源",
        "category": "雷动三千工具集",
        "icon": "$(trash)"
      },
      {
        "command": "leidong-tools.remoteTerminal.open",
        "title": "打开远程终端",
        "category": "雷动三千工具集",
        "icon": "$(terminal)"
      },
      {
        "command": "leidong-tools.remoteTerminal.runSavedCommand",
        "title": "在远程终端执行收藏/历史命令",
        "category": "雷动三千工具集",
        "icon": "$(history)"
      },
      {
        "command": "leidong-tools.sftp.compareCurrentFile",
        "title": "比较本地与远程文件",
        "category": "雷动三千工具集",
        "icon": "$(diff)"
      },
      {
        "command": "leidong-tools.sftp.syncCurrentFile",
        "title": "同步当前文件（比较后选择）",
        "category": "雷动三千工具集",
        "icon": "$(sync)"
      },
      {
        "command": "leidong-tools.sftp.testAllConnections",
        "title": "测试全部远程连接",
        "category": "雷动三千工具集",
        "icon": "$(debug-start)"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "leidong-tools.remoteTerminal",
          "title": "雷动远程终端",
          "icon": "terminal"
        }
      ]
    },
    "configuration": {
      "title": "Leidong Tools",
      "properties": {
        "leidong-tools.enableDefinitionJump": {
          "type": "boolean",
          "default": true,
          "description": "启用/关闭 Vue 变量和方法的定义跳转功能。关闭后将禁用所有跳转功能，包括 Go to Definition 和侧边栏跳转。"
        },
        "leidong-tools.indexLogging": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭索引与跳转调试日志输出（默认关闭，避免大量日志影响 Extension Host 性能）"
        },
        "leidong-tools.enableVueDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "启用/关闭 Vue 模板诊断（未使用变量检测、模板表达式未定义变量警告）。关闭后不再显示 Hint 和 Warning 诊断。"
        },
        "leidong-tools.rebuildOnSave": {
          "type": "boolean",
          "default": false,
          "description": "旧配置：是否允许保存时重建索引。建议改用 leidong-tools.indexBuildMode。默认关闭，避免频繁重建。"
        },
        "leidong-tools.indexBuildMode": {
          "type": "string",
          "default": "manual",
          "enum": [
            "manual",
            "onSave",
            "interval"
          ],
          "enumDescriptions": [
            "只在用户执行 Build Vue Index for Current File 或点击变量索引刷新按钮时构建。",
            "文件保存后构建当前文件索引，不在编辑中构建。",
            "按固定间隔构建可见且未修改的文件索引。"
          ],
          "description": "Vue 索引构建时机。默认 manual，所有语言功能只读取已有缓存，不会因为打开、切换、补全、Hover、诊断而自动构建。"
        },
        "leidong-tools.indexBuildIntervalMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "当 indexBuildMode 为 interval 时，构建可见未修改文件索引的间隔分钟数。"
        },
        "leidong-tools.maxIndexEntries": {
          "type": "number",
          "default": 200,
          "description": "Vue 索引缓存的最大条目数（LRU）。过高会占用更多内存。"
        },
        "leidong-tools.maxTemplateIndexEntries": {
          "type": "number",
          "default": 300,
          "description": "模板索引缓存的最大条目数（LRU）。过高会占用更多内存。"
        },
        "leidong-tools.cssIndexLinkCssEnabled": {
          "type": "boolean",
          "default": false,
          "description": "CSS 快速索引是否读取当前 HTML 中 link rel=stylesheet 引入的本地 CSS。默认关闭；开启后会自动跳过超过 cssIndexMaxFileLines 的超大 CSS。"
        },
        "leidong-tools.cssIndexMaxFileLines": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "CSS 自动索引的单文件行数上限，默认 2000 行。超过上限的 CSS 会跳过并提示；设为 0 表示不限制。"
        },
        "leidong-tools.cssIndexExtraPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "CSS 快速索引额外读取的 CSS 文件、目录或 glob。支持绝对路径、工作区相对路径、${workspaceFolder}、${fileDir}。"
        },
        "leidong-tools.cssIndexExcludePatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "CSS 快速索引排除规则。可填写路径片段/文件名，也可填写正则，例如 layui\\.css$ 或 (^|/)layui/。"
        },
        "leidong-tools.devScriptPatterns": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "自定义 HTML 对应 dev.js 的匹配路径（支持 ${dir} ${base}），可配置多个。为空时会回退到 js/ 同名.dev.js 的自动查找。"
        },
        "leidong-tools.watchHtmlVariableName": {
          "type": "string",
          "default": "html",
          "description": "HTML→JS 监听替换的变量名（例如 html / dom）。"
        },
        "leidong-tools.watchHtmlVariablePattern": {
          "type": "string",
          "default": "",
          "description": "HTML→JS 监听替换的自定义匹配正则（可选）。有值时优先使用。建议用分组捕获左侧赋值前缀，如 ^(\\s*(?:var|let|const)?\\s*dom\\s*=)"
        },
        "leidong-tools.hoverDelay": {
          "type": "number",
          "default": 300,
          "description": "鼠标悬停在变量上后延迟多少毫秒开始检测（默认300ms）。"
        },
        "leidong-tools.gameServerUrl": {
          "type": "string",
          "default": "http://gserver.srliforever.ltd",
          "description": "小游戏服务器 HTTP 地址。所有游戏页面由服务端提供，更新游戏无需更新扩展。开发环境设为 http://localhost:8088"
        },
        "leidong-tools.enableOutlineSymbols": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭面包屑导航和大纲视图增强。关闭后不再在 Outline 面板和面包屑中显示 Vue data/methods/computed 等分类符号。"
        },
        "leidong-tools.enableReferences": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭查找引用（Go to References）功能。支持在 HTML 模板和 JS 文件间跨文件查找 Vue 变量/方法的所有引用。"
        },
        "leidong-tools.enableCodeLens": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭 CodeLens 引用计数（需同时设置 codeLensPosition 选择显示位置）。"
        },
        "leidong-tools.codeLensPosition": {
          "type": "string",
          "default": "above",
          "enum": [
            "above",
            "right",
            "hover"
          ],
          "enumDescriptions": [
            "在定义行上方显示引用次数（CodeLens 样式）",
            "在定义行右侧行末装饰显示引用次数",
            "仅在鼠标悬停时显示引用次数"
          ],
          "description": "引用计数的显示位置。above: 上方 CodeLens; right: 行末装饰; hover: 鼠标悬停时显示。需先启用 enableCodeLens。"
        },
        "leidong-tools.enableColorPicker": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭智能颜色选择器。在 HTML 文件中检测 hex/rgb/hsl 颜色值并提供可视化颜色选择器。"
        },
        "leidong-tools.enableAIAnalysis": {
          "type": "boolean",
          "default": false,
          "description": "启用/关闭 AI 分析功能。开启后将在变量定义处显示「AI 分析」按钮。"
        },
        "leidong-tools.xTemplatePrettierOptions": {
          "type": "object",
          "default": {
            "printWidth": 160,
            "singleAttributePerLine": false
          },
          "description": "text/x-template 选区格式化使用的 Prettier 配置。会继承项目根目录 Prettier 配置，本设置中的字段优先级更高。默认属性不强制换行，printWidth 为 160。",
          "additionalProperties": true,
          "properties": {
            "printWidth": {
              "type": "number",
              "default": 160,
              "description": "Prettier printWidth，控制最大换行宽度。"
            },
            "singleAttributePerLine": {
              "type": "boolean",
              "default": false,
              "description": "Prettier singleAttributePerLine。false 表示不强制每个属性单独换行。"
            },
            "tabWidth": {
              "type": "number",
              "description": "Prettier tabWidth。未设置时使用当前编辑器 tabSize。"
            },
            "useTabs": {
              "type": "boolean",
              "description": "Prettier useTabs。未设置时使用当前编辑器 insertSpaces 推导。"
            }
          }
        },
        "leidong-tools.sftpConfigFiles": {
          "type": "array",
          "default": [
            ".vscode/sftp.json"
          ],
          "items": {
            "type": "string"
          },
          "description": "旧配置：远程连接配置文件列表。建议改用 leidong-tools.remoteConfigFiles。"
        },
        "leidong-tools.remoteConfigFiles": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "远程连接配置文件列表，支持 SFTP、SSH、FTP、FTPS。留空时读取 .vscode/sftp.json。"
        },
        "leidong-tools.remoteConnectionIdleTimeout": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "远程连接空闲多少秒后自动关闭。保存和连续操作会复用同一连接。"
        },
        "leidong-tools.remoteVerboseProtocolLogging": {
          "type": "boolean",
          "default": false,
          "description": "输出 SSH/SFTP/FTP 底层协议通信日志。仅建议排查连接问题时启用。"
        },
        "leidong-tools.remoteUploadExcludedExtensions": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "上传时排除的文件扩展名，不区分大小写，例如 node_modules 构建产物可填写 map、log、tmp。"
        },
        "leidong-tools.remoteUploadOnSaveEnabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用保存文件后自动上传。关闭后所有配置的 uploadOnSave 暂停生效。"
        },
        "leidong-tools.remoteUploadExcludeRegex": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "高级上传排除正则列表，匹配工作区相对路径（统一使用 / 分隔符），例如 (^|/)node_modules/、\\.min\\.js$。"
        },
        "leidong-tools.remoteTerminalFavoriteCommands": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "远程终端收藏命令。打开远程终端后，通过“在远程终端执行收藏/历史命令”选择执行。"
        },
        "leidong-tools.copilot.deepseekBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek 或其兼容服务的 OpenAI Chat Completions 基础地址。"
        },
        "leidong-tools.copilot.mimoBaseUrl": {
          "type": "string",
          "default": "https://api.xiaomimimo.com/v1",
          "description": "MiMo OpenAI 兼容 API 基础地址；按套餐需要可改为官方 Token Plan 地址。"
        },
        "leidong-tools.copilot.mimoAccessMode": {
          "type": "string",
          "default": "tokenPlan",
          "enum": ["tokenPlan", "payAsYouGo", "custom"],
          "enumDescriptions": [
            "MiMo TokenPlan 订阅；使用 tp- 密钥和选择的 TokenPlan 区域端点。",
            "MiMo 按量计费；使用 sk- 密钥和官方 api.xiaomimimo.com 端点。",
            "使用 mimoBaseUrl 中的自定义兼容端点。"
          ],
          "description": "MiMo 凭据和端点模式。TokenPlan 与按量计费密钥相互独立，不能混用。"
        },
        "leidong-tools.copilot.mimoTokenPlanRegion": {
          "type": "string",
          "default": "cn",
          "enum": ["cn", "sgp", "ams"],
          "enumDescriptions": ["中国集群", "新加坡集群", "欧洲集群"],
          "description": "MiMo TokenPlan OpenAI 兼容端点区域；以 TokenPlan 页面显示的专属地址为准。"
        },
        "leidong-tools.copilot.deepseekModelIdOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "将 Copilot 模型 ID 映射为 DeepSeek 或兼容端点实际模型 ID。"
        },
        "leidong-tools.copilot.mimoModelIdOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "将 MiMo 模型 ID 映射为 MiMo API 实际模型 ID；适用于官方模型更新或兼容网关。"
        },
        "leidong-tools.copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "自定义端点单次最大输出 token；0 表示交由模型 API 决定。"
        }
      }
    },
    "keybindings": [
      {
        "command": "leidong-tools.logVariable",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "leidong-tools.errorVariable",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      },
      {
        "command": "leidong-tools.quickConsoleLog",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !findInputFocussed && !replaceInputFocussed"
      },
      {
        "command": "leidong-tools.quickConsoleError",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "editorTextFocus && !findInputFocussed && !replaceInputFocussed && !inQuickOpen"
      },
      {
        "command": "leidong-tools.logSelectedVariable",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorHasSelection"
      },
      {
        "command": "leidong-tools.addVariableComment",
        "key": "ctrl+alt+/",
        "mac": "cmd+alt+/",
        "when": "editorTextFocus"
      },
      {
        "command": "leidong-tools.buildCurrentVueIndex",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus && (editorLangId == html || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == vue)"
      },
      {
        "command": "leidong-tools.formatXTemplateSelection",
        "key": "ctrl+k ctrl+f",
        "mac": "cmd+k cmd+f",
        "when": "editorTextFocus && editorLangId == html && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leidong-sidebar",
          "title": "雷动三千工具",
          "icon": "resources/remote-explorer.svg"
        }
      ]
    },
    "views": {
      "leidong-sidebar": [
        {
          "id": "leidong-tools.variableIndexWebview",
          "name": "变量索引",
          "type": "webview",
          "icon": "$(symbol-property)",
          "contextualTitle": "Vue 变量索引"
        },
        {
          "id": "leidong-tools.diagnosticsWebview",
          "name": "诊断面板",
          "type": "webview",
          "icon": "$(pulse)",
          "contextualTitle": "索引/缓存诊断"
        },
        {
          "id": "leidong-tools.watchServiceView",
          "name": "监听服务",
          "icon": "$(eye)",
          "contextualTitle": "文件监听服务"
        },
        {
          "id": "leidong-tools.gameSidebar",
          "name": "小游戏",
          "type": "webview",
          "icon": "$(game)",
          "contextualTitle": "小游戏大厅"
        },
        {
          "id": "leidong-tools.sftpView",
          "name": "远程资源",
          "type": "webview",
          "icon": "$(remote-explorer)",
          "contextualTitle": "远程资源管理器"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "leidong-tools.sftp.downloadCurrentFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "leidong-tools@1"
        },
        {
          "command": "leidong-tools.sftp.uploadFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "leidong-tools@2"
        },
        {
          "command": "leidong-tools.sftp.backupUpload",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "leidong-tools@3"
        },
        {
          "command": "leidong-tools.sftp.compareCurrentFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "leidong-tools@4"
        },
        {
          "command": "leidong-tools.sftp.syncCurrentFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "leidong-tools@5"
        },
        {
          "command": "leidong-tools.sftp.uploadFolder",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "leidong-tools@4"
        },
        {
          "command": "leidong-tools.buildCurrentVueIndex",
          "when": "resourceExtname == .html || resourceExtname == .js || resourceExtname == .ts || resourceExtname == .jsx || resourceExtname == .tsx || resourceExtname == .vue",
          "group": "leidong-tools@5"
        },
        {
          "command": "leidong-tools.startWatch",
          "when": "explorerResourceIsFolder",
          "group": "leidong-tools@6"
        }
      ],
      "editor/context": [
        {
          "command": "leidong-tools.sftp.downloadCurrentFile",
          "when": "resourceScheme == file",
          "group": "leidong-tools@1"
        },
        {
          "command": "leidong-tools.sftp.uploadCurrentFile",
          "when": "resourceScheme == file",
          "group": "leidong-tools@2"
        },
        {
          "command": "leidong-tools.sftp.backupUpload",
          "when": "resourceScheme == file",
          "group": "leidong-tools@3"
        },
        {
          "command": "leidong-tools.sftp.compareCurrentFile",
          "when": "resourceScheme == file",
          "group": "leidong-tools@4"
        },
        {
          "command": "leidong-tools.sftp.syncCurrentFile",
          "when": "resourceScheme == file",
          "group": "leidong-tools@5"
        },
        {
          "command": "leidong-tools.buildCurrentVueIndex",
          "when": "editorLangId == html || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact || editorLangId == vue",
          "group": "leidong-tools@4"
        },
        {
          "command": "leidong-tools.formatXTemplateSelection",
          "when": "editorLangId == html && editorHasSelection",
          "group": "leidong-tools@5"
        },
        {
          "command": "leidong-tools.compressLines",
          "when": "editorHasSelection",
          "group": "leidong-tools@6"
        }
      ],
      "view/item/context": [
        {
          "command": "leidong-tools.sftp.preview",
          "when": "view == leidong-tools.sftpView && viewItem == remote-file",
          "group": "inline@1"
        },
        {
          "command": "leidong-tools.sftp.download",
          "when": "view == leidong-tools.sftpView && (viewItem == remote-file || viewItem == remote-directory || viewItem == remote-profile)",
          "group": "inline@2"
        },
        {
          "command": "leidong-tools.sftp.upload",
          "when": "view == leidong-tools.sftpView && (viewItem == remote-directory || viewItem == remote-profile)",
          "group": "inline@3"
        },
        {
          "command": "leidong-tools.sftp.backupUpload",
          "when": "view == leidong-tools.sftpView && viewItem == remote-file",
          "group": "inline@4"
        },
        {
          "command": "leidong-tools.sftp.selectAutoUploadProfile",
          "when": "view == leidong-tools.sftpView && viewItem == remote-profile",
          "group": "2_workspace@1"
        },
        {
          "command": "leidong-tools.sftp.createDirectory",
          "when": "view == leidong-tools.sftpView && (viewItem == remote-directory || viewItem == remote-profile)",
          "group": "1_modification@1"
        },
        {
          "command": "leidong-tools.sftp.rename",
          "when": "view == leidong-tools.sftpView && (viewItem == remote-file || viewItem == remote-directory)",
          "group": "1_modification@2"
        },
        {
          "command": "leidong-tools.sftp.delete",
          "when": "view == leidong-tools.sftpView && (viewItem == remote-file || viewItem == remote-directory)",
          "group": "1_modification@3"
        },
        {
          "command": "leidong-tools.pauseWatch",
          "when": "viewItem == watch-running",
          "group": "inline@1"
        },
        {
          "command": "leidong-tools.resumeWatch",
          "when": "viewItem == watch-paused",
          "group": "inline@1"
        },
        {
          "command": "leidong-tools.pauseWatch",
          "when": "viewItem == watch-running",
          "group": "1_modification@1"
        },
        {
          "command": "leidong-tools.resumeWatch",
          "when": "viewItem == watch-paused",
          "group": "1_modification@1"
        }
      ],
      "view/title": [
        {
          "command": "leidong-tools.sftp.refresh",
          "when": "view == leidong-tools.sftpView",
          "group": "navigation@1"
        },
        {
          "command": "leidong-tools.sftp.openConfig",
          "when": "view == leidong-tools.sftpView",
          "group": "navigation@2"
        },
        {
          "command": "leidong-tools.sftp.showLogs",
          "when": "view == leidong-tools.sftpView",
          "group": "navigation@3"
        }
      ]
    },
    "semanticTokenScopes": [
      {
        "language": "html",
        "scopes": {
          "type.declaration": [
            "entity.name.function.method"
          ]
        }
      }
    ],
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "source.js.jsx",
          "source.tsx"
        ],
        "scopeName": "inline.template-literal-html",
        "path": "./syntaxes/template-literal-html.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css"
        }
      },
      {
        "injectTo": [
          "text.html.basic"
        ],
        "scopeName": "inline.x-template-html",
        "path": "./syntaxes/x-template-html.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html"
        }
      },
      {
        "injectTo": [
          "text.html.basic"
        ],
        "scopeName": "inline.laytpl-html",
        "path": "./syntaxes/layui-template-html.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript.laytpl": "javascript",
          "meta.embedded.inline.javascript.laytpl": "javascript"
        },
        "tokenTypes": {
          "meta.embedded.block.javascript.laytpl": "other",
          "meta.embedded.inline.javascript.laytpl": "other",
          "comment.block.laytpl": "comment"
        }
      }
    ],
    "semanticTokenProvider": {
      "selector": [
        {
          "language": "html"
        }
      ],
      "id": "htmlVueSemanticTokensProvider"
    },
    "semanticTokenTypes": [
      {
        "id": "type",
        "description": "Represents a general type, used here for component tags."
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "declaration",
        "description": "Indicates that a definition for the token was found."
      },
      {
        "id": "readonly",
        "description": "Placeholder modifier."
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vsix": "vsce package",
    "publish": "vsce publish",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@vue/compiler-dom": "^3.5.39",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "axios": "^1.18.1",
    "basic-ftp": "^6.0.1",
    "cheerio": "^1.2.0",
    "prettier": "^3.9.5",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1",
    "vue-template-compiler": "^2.7.15"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@types/babel__traverse": "^7.20.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.39.5",
    "ts-loader": "^9.6.2",
    "typescript": "^5.8.2",
    "webpack": "^5.108.4",
    "webpack-cli": "^6.0.1"
  }
}
